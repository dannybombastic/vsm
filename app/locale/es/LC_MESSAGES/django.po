# ── index.html – Steps section (updated) ────────────────────────

msgid "These are the steps to generate your Value Stream Map using AI or the Admin panel."
msgstr "Estos son los pasos para generar tu Mapa de Flujo de Valor usando IA o el panel de Admin."

msgid "Option A: Questionnaire Flow (AI)"
msgstr "Opción A: Flujo por Cuestionarios (IA)"

msgid "Option B: Admin Flow (Manual)"
msgstr "Opción B: Flujo Admin (Manual)"

msgid "From the Admin panel, create the departments that participate in the value stream."
msgstr "Desde el panel de Admin, crea los departamentos que participan en el flujo de valor."

msgid "Configure questionnaire forms for each department with their specific questions and metrics."
msgstr "Configura formularios de cuestionario para cada departamento con sus preguntas y métricas específicas."

msgid "Create and configure projects directly from the administration panel."
msgstr "Crea y configura proyectos directamente desde el panel de administración."

msgid "Build the Value Stream Map manually from Admin without using AI, entering metrics and flow data directly."
msgstr "Construye el Mapa de Flujo de Valor manualmente desde Admin sin usar IA, ingresando métricas y datos de flujo directamente."

# ── index.html – Admin card (updated) ───────────────────────────

msgid "From Admin you can manage users and roles, create departments, configure forms, create projects and build VSMs manually."
msgstr "Desde Admin puedes gestionar usuarios y roles, crear departamentos, configurar formularios, crear proyectos y construir VSMs manualmente."

msgid "Manage users, roles, departments, forms, projects and VSMs."
msgstr "Gestiona usuarios, roles, departamentos, formularios, proyectos y VSMs."

