# ── index.html – Steps ──────────────────────────────────────────

msgid "These are the 7 steps to generate your Value Stream Map."
msgstr "Estos son los 7 pasos para generar tu Mapa de Flujo de Valor."

msgid "Steps to generate your Value Stream Map"
msgstr "Pasos para generar tu Mapa de Flujo de Valor"

msgid "Create a Project"
msgstr "Crear un Proyecto"

msgid "Go to Projects and create or select a project. Each project groups its questionnaires and VSMs."
msgstr "Ve a Proyectos y crea o selecciona un proyecto. Cada proyecto agrupa sus cuestionarios y VSMs."

msgid "Within the project, each team fills their questionnaire with process metrics, times and issues."
msgstr "Dentro del proyecto, cada equipo rellena su cuestionario con métricas de proceso, tiempos y problemas."

msgid "Verify there are enough team responses before generating the VSM."
msgstr "Verifica que hay suficientes respuestas de los equipos antes de generar el VSM."

msgid "AI analyzes the responses and automatically generates a Value Stream Map with time metrics."
msgstr "La IA analiza las respuestas y genera automáticamente un Mapa de Flujo de Valor con métricas de tiempo."

msgid "Save the VSM"
msgstr "Guardar el VSM"

msgid "Review the generated VSM, adjust if necessary, and save it to the database."
msgstr "Revisa el VSM generado, ajusta si es necesario y guárdalo en la base de datos."

msgid "Visualize the Map"
msgstr "Visualizar el Mapa"

msgid "Explore the interactive Value Stream Map with work times, wait times, rework and bottlenecks."
msgstr "Explora el Mapa de Flujo de Valor interactivo con tiempos de trabajo, tiempos de espera, retrabajo y cuellos de botella."

msgid "Collect new responses, regenerate the VSM and compare to measure continuous improvement."
msgstr "Recoge nuevas respuestas, regenera el VSM y compara para medir la mejora continua."

